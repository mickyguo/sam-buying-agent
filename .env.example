# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sam_buying_agent"

# Auth (H5 商城 JWT)
JWT_SECRET="change-me-in-production"

# Better Auth (邮箱密码登录)
BETTER_AUTH_SECRET="change-me-run-npx-auth-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Admin
ADMIN_PASSWORD="admin123"

# WeChat (optional for dev)
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"
# 可选。H5 商城 API 请求在浏览器端自动使用当前域名，无需随部署变化而修改。
# 仅在没有 HTTP 请求上下文时作为回退（如本地开发、Better Auth 初始化）。
# 微信 OAuth / 支付回调已在服务端按请求头自动推断域名；正式上线建议绑定固定自定义域名并在微信公众平台配置。

# WeChat Pay (optional — dev mode mock when unset)
WECHAT_MCH_ID=""
WECHAT_MCH_SERIAL_NO=""
WECHAT_MCH_PRIVATE_KEY=""
WECHAT_MCH_API_V3_KEY=""
WECHAT_MCH_NOTIFY_URL=""

# SMS dev mode
SMS_DEV_MODE="true"
SMS_DEV_CODE="123456"

# Pickup (self-collection only)
PICKUP_LOCATION="XX山姆代购自提点，每日 18:00-21:00 可取货"

# Group order
GROUP_ORDER_EXPIRE_HOURS="24"
ORDER_PAY_TIMEOUT_MINUTES="30"

# Sam's product import
# 方式一：Python 脚本本地代理（见 README「Python 抓取脚本」）
# SAMS_PRODUCT_API_URL="http://127.0.0.1:8765/api/goods/{id}"
# 方式二：自定义商品详情 API
# SAMS_PRODUCT_API_URL="https://example.com/api/goods/{id}"
SAMS_IMPORT_DEV_MODE="true"

# Cron protection (optional)
CRON_SECRET=""

# LLM AI assistant (optional — falls back to rule engine when unset)
LLM_API_KEY=""
LLM_API_BASE_URL="https://api.cursor.com/v1"
LLM_MODEL="composer-2.5"
# Cursor Composer 变体：不设或 false 为标准版，true 为 fast 版（更贵）
LLM_MODEL_FAST="false"

# WeChat subscribe message templates (optional — falls back to WECHAT_SUBSCRIBE_TEMPLATE_ID)
WECHAT_SUBSCRIBE_TEMPLATE_ID=""
WECHAT_TEMPLATE_GROUP_FILLED=""
WECHAT_TEMPLATE_GROUP_EXPIRED=""
WECHAT_TEMPLATE_GROUP_ALMOST_FULL=""
WECHAT_TEMPLATE_PICKUP_READY=""
WECHAT_TEMPLATE_PRICE_DROP=""
WECHAT_TEMPLATE_PRODUCT_AVAILABLE=""
